{
  "name": "lead-generator",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"pnpm --filter @lead-generator/backend dev\" \"pnpm --filter @lead-generator/frontend dev\"",
    "build": "pnpm --filter @lead-generator/shared build && pnpm -r build",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.7.0"
  }
}
